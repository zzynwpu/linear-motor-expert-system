{
  "template_id": "tpl_bldc_startup_v1",
  "name": "BLDC startup and stall scenario screening",
  "simulation_level": "system",
  "applicable_motor_types": ["bldc", "servo"],
  "applicable_task_types": ["design_advice", "risk_analysis", "test_case_generation"],
  "required_inputs": [
    "bus_voltage_v",
    "rated_power_w",
    "phase_resistance_ohm",
    "phase_inductance_mh",
    "pole_pairs",
    "control_mode"
  ],
  "default_sweeps": [
    {
      "name": "load_mode",
      "type": "list",
      "values": ["startup_no_load", "rated_load", "stall_event"]
    },
    {
      "name": "temperature_c",
      "type": "corner",
      "values": [25, 85]
    }
  ],
  "key_measurements": [
    "startup_time_ms",
    "phase_current_peak",
    "fault_trip_time_us",
    "dc_bus_ripple_v"
  ],
  "pass_criteria": [
    {
      "metric": "startup_time_ms",
      "operator": "<=",
      "value": 500.0,
      "unit": "ms"
    }
  ],
  "known_limitations": [
    "Controller tuning parameters should be supplied explicitly for meaningful results.",
    "Mechanical load abstraction may need project-specific refinement."
  ],
  "recommended_tools": ["plecs", "psim", "simulink"],
  "recommended_provider_ids": ["simulink_online_browser", "agent_remote_sim_connector"],
  "version": "0.1.0"
}

{
  "template_id": "tpl_gate_ringing_v1",
  "name": "Gate-drive ringing and overshoot screening",
  "simulation_level": "circuit",
  "applicable_motor_types": ["bldc", "servo", "stepper"],
  "applicable_task_types": ["schematic_review", "layout_review", "risk_analysis"],
  "required_inputs": [
    "bus_voltage_v",
    "gate_res_ohm",
    "driver_peak_current_a",
    "mosfet_part",
    "estimated_loop_inductance_nh"
  ],
  "default_sweeps": [
    {
      "name": "gate_res_ohm",
      "type": "corner",
      "values": [2.2, 5.1, 10.0, 20.0]
    },
    {
      "name": "estimated_loop_inductance_nh",
      "type": "corner",
      "values": [5, 15, 30]
    }
  ],
  "key_measurements": [
    "vgs_peak",
    "vds_overshoot",
    "ringing_cycles"
  ],
  "pass_criteria": [
    {
      "metric": "vds_overshoot",
      "operator": "<=",
      "value": 12.0,
      "unit": "V"
    }
  ],
  "known_limitations": [
    "This template is sensitive to assumed parasitics.",
    "EMI compliance still requires lab correlation."
  ],
  "recommended_tools": ["ngspice", "ltspice"],
  "recommended_provider_ids": ["remote_ngspice_service", "agent_remote_sim_connector"],
  "version": "0.1.0"
}
